# ─── DotaBURGUERS — Environment Variables ───
# Copia este archivo como .env y completá los valores.
# Las variables VITE_* son accesibles desde el frontend (Vite).

# === API ===
# URL base del backend API
VITE_API_BASE_URL=https://dummyjson.com
# Endpoint para autenticación por username
VITE_AUTH_USERNAME_ENDPOINT=/users/filter

# === Stripe (futuro) ===
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# === CDN / Assets (futuro) ===
# VITE_IMAGE_CDN_BASE=https://cdn.dotaburgers.com
