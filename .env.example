# ──────────────────────────────────────────────
# DotaBURGUERS — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Stripe keys are REQUIRED for payment processing.
# External API URLs have working defaults (FakeStore, DummyJSON).

# ── Stripe (Payment Processing) ───────────────
# REQUIRED. Get your keys at https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY

# Stripe server endpoint (for creating PaymentIntents)
# Default: the built-in Stripe server runs on port 3001
#   node server/stripe-server.mjs
VITE_STRIPE_SERVER_URL=http://localhost:3001

# ── External APIs (Production) ────────────────
# These have working defaults — override only if needed.
VITE_FAKESTORE_API=https://fakestoreapi.com
VITE_DUMMYJSON_API=https://dummyjson.com

# ── Application ───────────────────────────────
VITE_APP_NAME=DotaBURGUERS
VITE_APP_URL=http://localhost:5173
